---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles");
const latest = allArticles
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 6);

const categories = [
  { name: "仕事術", icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`, class: "cat-work", desc: "段取り・効率・時間管理" },
  { name: "ビジネスマインド", icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-1.79-3.71 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.27-1.51Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 1.79-3.71 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.27-1.51Z"/></svg>`, class: "cat-mind", desc: "思考法・意思決定・戦略" },
  { name: "人間力", icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-9"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 1 1.1 4.8 4 4 0 0 1-4 3 4 4 0 0 1 .6-2.9C12.1 9.1 13.1 7.1 14.1 6"/></svg>`, class: "cat-human", desc: "コミュニケーション・自己成長" },
];
---

<BaseLayout title="ホーム">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <h1 class="hero-title">自分を磨く人のための<br />ナレッジベース</h1>
        <p class="hero-sub">仕事術・ビジネスマインド・人間力——<br />日々の行動を変えるヒントを届ける</p>
      </div>
      <div class="hero-kira">
        <img src="/kira.png" alt="Kira" />
        <p class="kira-caption">ライター「Kira」</p>
      </div>
    </div>
  </section>

  <div class="container">
    <section class="section">
      <div class="category-banners">
        {categories.map(cat => (
          <a href={`/category/${cat.name}`} class={`category-banner ${cat.class}`}>
            <span class="cat-icon"><Fragment set:html={cat.icon} /></span>
            {cat.name}
            <div style="font-size:0.8rem;font-weight:400;opacity:0.85;margin-top:0.25rem">{cat.desc}</div>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">最新の記事</h2>
      <div class="cards">
        {latest.map(article => (
          <a href={`/articles/${article.id}`} class="card">
            <span class="card-category">{article.data.category}</span>
            <h3 class="card-title">{article.data.title}</h3>
            <p class="card-desc">{article.data.description}</p>
            <p class="card-date">{article.data.publishedAt}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
